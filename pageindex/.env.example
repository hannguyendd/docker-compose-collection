# Required: OpenAI API key for PageIndex document processing
CHATGPT_API_KEY=your_openai_api_key_here

# Optional: Host port mapping (default: 8090)
PAGEINDEX_PORT=8090

# Optional: OpenAI model to use (default: gpt-4o)
PAGEINDEX_MODEL=gpt-4o

# Optional: Number of pages to scan for table of contents (default: 20)
PAGEINDEX_TOC_CHECK_PAGES=20

# Optional: Maximum pages per tree node (default: 10)
PAGEINDEX_MAX_PAGES_PER_NODE=10

# Optional: Maximum tokens per tree node (default: 20000)
PAGEINDEX_MAX_TOKENS_PER_NODE=20000
